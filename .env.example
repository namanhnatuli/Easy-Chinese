# ==========================================
# Core app + Supabase
# ==========================================

# URL project Supabase.
# Lấy ở đâu: Supabase Dashboard -> Project Settings -> API -> Project URL
# Dùng để: client và server kết nối vào project Supabase.
NEXT_PUBLIC_SUPABASE_URL=

# Anon/public key của Supabase.
# Lấy ở đâu: Supabase Dashboard -> Project Settings -> API -> anon / publishable key
# Dùng để: client-side auth, query public data, SSR client với quyền public.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key của Supabase, chỉ dùng phía server.
# Lấy ở đâu: Supabase Dashboard -> Project Settings -> API -> service_role key
# Dùng để: admin actions, bootstrap role admin, ghi cache TTS, signed URL, cập nhật metadata an toàn.
SUPABASE_SERVICE_ROLE_KEY=

# Danh sách email admin, phân tách bằng dấu phẩy.
# Lấy ở đâu: tự điền email của team/admin thật
# Dùng để: server nâng role người dùng lên `admin` sau khi đăng nhập.
ADMIN_EMAILS=

# Tên app hiển thị ở UI/public shell.
# Lấy ở đâu: tự đặt
# Dùng để: branding cơ bản trong giao diện.
NEXT_PUBLIC_APP_NAME=Chinese Learning App

# Locale mặc định của app.
# Lấy ở đâu: tự chọn, hiện app hỗ trợ `en`, `vi`, `zh`
# Dùng để: fallback ngôn ngữ cho route và UI trước khi user chọn preference.
NEXT_PUBLIC_DEFAULT_LOCALE=en

# ==========================================
# AI / Gemini
# ==========================================

# Danh sách Gemini API keys.
# Lấy ở đâu: Google AI Studio -> Get API key
# Dùng để: server xoay vòng key theo round-robin, không bao giờ expose ra client.
GEMINI_API_KEYS=["key1","key2","key3"]

# Danh sách model Gemini kèm trọng số chọn.
# Lấy ở đâu: tự cấu hình theo chiến lược cost/performance của app
# Dùng để: weighted model selection trong server-side AI layer.
GEMINI_MODEL_WEIGHTS=[{"model":"gemini-3.1-flash-lite-preview","weight":5},{"model":"gemini-2.5-flash","weight":2},{"model":"gemini-2.5-flash-lite","weight":1},{"model":"gemini-3-flash-preview","weight":1}]

# Số lần retry tối đa khi gặp rate limit hoặc lỗi provider tạm thời.
# Lấy ở đâu: tự đặt
# Dùng để: retry sang key/model khác trong Gemini client wrapper.
GEMINI_MAX_RETRIES=3

# Timeout cho mỗi request Gemini tính bằng milliseconds.
# Lấy ở đâu: tự đặt
# Dùng để: tránh request treo quá lâu ở server.
GEMINI_TIMEOUT_MS=30000

# Temperature mặc định cho Gemini text generation.
# Lấy ở đâu: tự đặt theo mức sáng tạo mong muốn
# Dùng để: fallback chung cho AI service nếu caller không truyền riêng.
GEMINI_DEFAULT_TEMPERATURE=0.4

# Max output tokens mặc định cho Gemini text generation.
# Lấy ở đâu: tự đặt theo độ dài output mong muốn và giới hạn model
# Dùng để: kiểm soát chi phí và độ dài phản hồi AI.
GEMINI_DEFAULT_MAX_OUTPUT_TOKENS=2048

# Deprecated OpenAI variables.
# Lấy ở đâu: để trống nếu đã migrate xong
# Dùng để: giữ tương thích tạm thời với môi trường cũ, nhưng app không còn gọi OpenAI trực tiếp.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=

# ==========================================
# TTS / Pronunciation
# ==========================================

# Tốc độ đọc mặc định.
# Lấy ở đâu: tự đặt, không lấy từ dashboard
# Dùng để: UX học tập; giá trị < 1.0 giúp đọc chậm hơn cho người học.
TTS_DEFAULT_SPEAKING_RATE=0.82

# Cao độ giọng mặc định.
# Lấy ở đâu: tự đặt
# Dùng để: tinh chỉnh pitch của giọng đọc; `0` là trung tính.
TTS_DEFAULT_PITCH=0

# Tên bucket Supabase Storage dùng để lưu audio cache.
# Lấy ở đâu: phải trùng bucket đã tạo trong Supabase; migration hiện dùng `tts-audio`
# Dùng để: upload và đọc file mp3 đã generate.
TTS_STORAGE_BUCKET=tts-audio

# Chế độ truy cập bucket.
# Lấy ở đâu: tự chọn `public` hoặc `private`, nhưng phải khớp policy bucket thật
# Dùng để: app quyết định trả public URL hay signed URL.
TTS_STORAGE_ACCESS=public

# Số ký tự tối đa cho mỗi request TTS.
# Lấy ở đâu: tự đặt guardrail
# Dùng để: chặn request quá dài để kiểm soát cost.
TTS_MAX_CHARACTERS_PER_REQUEST=280

# Danh sách language code cho phép, phân tách bằng dấu phẩy.
# Lấy ở đâu: tự đặt theo policy app; hiện app chỉ support `zh-CN`
# Dùng để: validation phía server trước khi gọi provider.
TTS_ALLOWED_LANGUAGE_CODES=zh-CN

# Giới hạn request/phút cho anonymous users.
# Lấy ở đâu: tự đặt
# Dùng để: placeholder rate-limit app-level để tránh abuse; hiện chưa phải distributed rate limiter.
TTS_ANONYMOUS_REQUEST_LIMIT_PER_MINUTE=30

# Provider-specific server-only credentials

# Azure Speech API key.
# Lấy ở đâu: Azure Portal -> Speech resource -> Keys and Endpoint -> KEY 1 / KEY 2
# Dùng để: server gọi Azure Neural TTS.
AZURE_SPEECH_KEY=

# Azure Speech region.
# Lấy ở đâu: Azure Portal -> Speech resource -> Overview / Keys and Endpoint
# Dùng để: build endpoint dạng `{region}.tts.speech.microsoft.com`.
AZURE_SPEECH_REGION=

# Google Cloud Text-to-Speech API key.
# Lấy ở đâu: Google Cloud Console -> APIs & Services -> Credentials
# Dùng để: server gọi Google TTS nếu chọn provider `google`.
GOOGLE_TTS_API_KEY=

# ==========================================
# Local Supabase Google OAuth
# ==========================================

# Google OAuth Client ID cho local Supabase Auth.
# Lấy ở đâu: Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client ID
# Dùng để: đăng nhập Google khi chạy `supabase start` local.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=

# Google OAuth Client Secret cho local Supabase Auth.
# Lấy ở đâu: cùng chỗ với Client ID ở Google Cloud Console
# Dùng để: hoàn tất Google OAuth flow cho local Supabase.
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# ==========================================
# Google Sheets preview sync (server-side only)
# ==========================================

# Option A: toàn bộ service account JSON trong một biến.
# Lấy ở đâu: Google Cloud Console -> IAM & Admin -> Service Accounts -> Keys -> JSON key file
# Dùng để: server đọc Google Sheets cho preview sync/admin import.
GOOGLE_SERVICE_ACCOUNT_CREDENTIALS_JSON=

# Option B: email của service account.
# Lấy ở đâu: trong JSON key file của service account (`client_email`)
# Dùng để: xác thực server với Google nếu không dùng biến JSON full.
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=

# Option B: private key của service account.
# Lấy ở đâu: trong JSON key file của service account (`private_key`)
# Dùng để: xác thực server với Google nếu không dùng biến JSON full.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Spreadsheet ID mặc định cho preview sync.
# Lấy ở đâu: từ URL Google Sheets, đoạn giữa `/d/` và `/edit`
# Dùng để: admin không phải nhập lại spreadsheet mỗi lần preview.
GOOGLE_SHEETS_DEFAULT_SPREADSHEET_ID=

# Tên sheet/tab mặc định trong spreadsheet.
# Lấy ở đâu: tên tab ở cuối file Google Sheets
# Dùng để: prefill source sheet cho preview sync.
GOOGLE_SHEETS_DEFAULT_SHEET_NAME=

# Tên sheet/tab cho grammar sync. Dùng cùng spreadsheet ID với preview sync.
GOOGLE_SHEETS_GRAMMAR_SHEET_NAME=

# ==========================================
# Notes
# ==========================================

# - Mọi biến `NEXT_PUBLIC_*` đều lộ ra client, không được đặt secret vào đó.
# - Biến TTS/Azure/Google/Service Role phải chỉ tồn tại phía server.
# - Bucket `tts-audio` phù hợp với audio học tập không nhạy cảm; nếu đổi sang private thì app sẽ dùng signed URL.
# - `GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY` phải giữ đúng line breaks hoặc dùng `\n`.
# - User settings trước khi đăng nhập sẽ fallback:
#   - language -> NEXT_PUBLIC_DEFAULT_LOCALE
#   - theme -> system
#   - font -> sans
