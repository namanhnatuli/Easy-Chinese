NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_EMAILS=

# For local Supabase Google OAuth via `supabase start`
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

NEXT_PUBLIC_APP_NAME=Chinese Learning App
NEXT_PUBLIC_DEFAULT_LOCALE=vi

# Profile-backed user settings use these defaults before sign-in:
# - language falls back to NEXT_PUBLIC_DEFAULT_LOCALE
# - theme falls back to "system"
# - font falls back to "sans"

# Operational notes:
# - NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY are validated at runtime
# - SUPABASE_SERVICE_ROLE_KEY is required for secure admin/bootstrap flows
# - ADMIN_EMAILS is a comma-separated admin allowlist
