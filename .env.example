NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_EMAILS=

# For local Supabase Google OAuth via `supabase start`
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# Google Sheets preview sync (server-side only)
# Option A: paste the full service account JSON in one env var
GOOGLE_SERVICE_ACCOUNT_CREDENTIALS_JSON=
# Option B: provide the key parts separately
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# Optional default spreadsheet for preview requests
GOOGLE_SHEETS_DEFAULT_SPREADSHEET_ID=
GOOGLE_SHEETS_DEFAULT_SHEET_NAME=

NEXT_PUBLIC_APP_NAME=Chinese Learning App
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Profile-backed user settings use these defaults before sign-in:
# - language falls back to NEXT_PUBLIC_DEFAULT_LOCALE
# - theme falls back to "system"
# - font falls back to "sans"

# Operational notes:
# - NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY are validated at runtime
# - SUPABASE_SERVICE_ROLE_KEY is required for secure admin/bootstrap flows
# - ADMIN_EMAILS is a comma-separated admin allowlist
# - Google Sheets credentials stay server-side and must never use NEXT_PUBLIC_ prefixes
# - GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY should preserve line breaks or use \n escapes
